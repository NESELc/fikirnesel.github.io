    },
    {
      "id": "bogaz-agrisi",
      "ad": "Boğaz ağrısı",
      "uyari": "Yüksek ateş, nefes alma güçlüğü, yutamama veya 3 günden uzun süren şikayette doktora başvurun."
    },
    {
      "id": "hazimsizlik",
      "ad": "Hazımsızlık",
      "uyari": "Göğüs ağrısı, kilo kaybı, yutma güçlüğü veya uzun süren şikayette doktora başvurun."
    },
    {
      "id": "ishal",
      "ad": "İshal",
      "uyari": "Kanlı ishal, ateş, sıvı kaybı, bebek/yaşlı hasta veya 2 günden uzun sürme durumunda doktora başvurun."
    },
    {
      "id": "kabizlik",
      "ad": "Kabızlık",
      "uyari": "Şiddetli karın ağrısı, kanama, kusma veya uzun süre dışkılayamama varsa doktora başvurun."
    },
    {
      "id": "mide-bulantisi",
      "ad": "Mide bulantısı",
      "uyari": "Sürekli kusma, kan, ateş, gebelik veya sıvı kaybında doktora başvurun."
    },
    {
      "id": "nefes-sorunu",
      "ad": "Nefes sorunu",
      "uyari": "Nefes darlığı acil belirti olabilir; gıda önerisi yerine tıbbi destek alın."
    },
    {
      "id": "oksuruk",
      "ad": "Öksürük",
      "uyari": "Nefes darlığı, kanlı balgam, göğüs ağrısı veya uzun süren öksürükte doktora başvurun."
    },
    {
      "id": "uykusuzluk",
      "ad": "Uykusuzluk",
      "uyari": "Uzun süren uykusuzluk, gündüz işlev kaybı veya ilaç/psikolojik durum eşlik ediyorsa uzman desteği alın."
    },
    {
      "id": "yorgunluk",
      "ad": "Yorgunluk",
      "uyari": "Uzun süren, ani başlayan veya kilo kaybı/nefes darlığıyla birlikte olan yorgunlukta tıbbi değerlendirme gerekir."
